PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/portfolio_db
JWT_SECRET=change-me-min-10-chars
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
# Optional: comma-separated extra Origins (e.g. Vercel preview URLs). Trailing slashes are ignored.
# ADDITIONAL_CORS_ORIGINS=https://user-frontend-git-main-xxx.vercel.app

# Optional: Cloudinary (if CLOUDINARY_CLOUD_NAME is set, key and secret are required)
# CLOUDINARY_URL=
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# CLOUDINARY_FOLDER=portfolio

# Optional: SMTP (if SMTP_HOST is set, user and pass are required)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# SMTP_SECURE=false
# SMTP_NOTIFY_TO=
